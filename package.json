{
  "name": "ai-store-analysis-system",
  "version": "1.0.0",
  "private": true,
  "description": "Fuzhou Store AI Analysis System Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "python3 -m uvicorn apps.api.src.main:app --host 0.0.0.0 --port 3000 --reload --reload-dir apps --reload-dir packages",
    "dev": "npm run dev:api",
    "start": "npm run dev:api"
  }
}
